# ─── Next.js ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ─── School Info ──────────────────────────────────────────────
NEXT_PUBLIC_SCHOOL_NAME_KM=សាលា​មធ្យមសិក្សា​...
NEXT_PUBLIC_SCHOOL_NAME_EN=Kamrieng Hight School
NEXT_PUBLIC_SCHOOL_PROVINCE=Battambang
NEXT_PUBLIC_SCHOOL_PHONE=+855 23 000 000
NEXT_PUBLIC_SCHOOL_EMAIL=reachtalab@gmail.com
NEXT_PUBLIC_SCHOOL_FACEBOOK=https://facebook.com/school
NEXT_PUBLIC_SCHOOL_YOUTUBE=https://youtube.com/@school

# ─── Firebase ─────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# ─── Firebase Admin (server-side, for session verification) ──
# From Firebase Console → Project settings → Service accounts →
# Generate new private key. Copy values from the downloaded JSON.
# Keep the quotes around the private key; \n stays as literal \n.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Contact Form (Nodemailer) ────────────────────────────────
# Gmail account used to SEND contact form emails
EMAIL_USER=your_gmail@gmail.com
# Gmail App Password (generate at https://myaccount.google.com/apppasswords)
EMAIL_PASSWORD=your_app_password
# Where contact form submissions are sent to
CONTACT_EMAIL=reachtalab@gmail.com

# ─── Telegram Bot ─────────────────────────────────────────────
# Your bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token
# Your Telegram Chat ID (message @userinfobot to get it)
TELEGRAM_CHAT_ID=your_chat_id
